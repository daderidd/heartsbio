---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhosphorusStoryMap from '../components/PhosphorusStoryMap';

const MAPBOX_TOKEN = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const hasMapboxToken = Boolean(MAPBOX_TOKEN);
---

<BaseLayout
  title="The Phosphorus Paradox — HeartsBio"
  description="Agricultural soils contain large residual phosphorus stocks, much of it poorly available. HeartsBio's enzyme technology aims to improve access to these trapped phosphorus fractions."
  keywords="phosphorus crisis, legacy phosphorus, soil phosphorus Europe, phosphate depletion, eutrophication, HeartsBio, Fitazim, Bio-Dop, sustainable agriculture, phosphorus recovery"
>
  <!-- Hero -->
  <section class="relative bg-[#111] overflow-hidden">
    <div class="container-custom pt-32 pb-12 md:pt-40 md:pb-16 text-center relative z-10">
      <div class="inline-block mb-4 px-4 py-2 bg-white/5 rounded-full">
        <span class="text-white/60 font-semibold text-sm tracking-wide">THE PHOSPHORUS PARADOX</span>
      </div>
      <h1 class="text-white mb-6 max-w-4xl mx-auto">
        A critical nutrient, strategically constrained — and widely wasted
      </h1>
      <p class="text-lg md:text-xl text-white/50 max-w-2xl mx-auto mb-8">
        Scroll to explore how phosphorus inefficiency threatens global food security — and where the opportunity lies.
      </p>
      <div class="flex items-center justify-center gap-2 text-white/30 text-sm">
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
        <span>Scroll to explore</span>
      </div>
    </div>
  </section>

  <!-- Story Map -->
  {hasMapboxToken ? (
    <PhosphorusStoryMap client:only="react" mapboxToken={MAPBOX_TOKEN!} />
  ) : (
    <section class="bg-[#111] py-20">
      <div class="container-custom max-w-3xl">
        <div class="rounded-2xl border border-white/10 bg-black/40 p-8 text-white">
          <div class="inline-block mb-4 px-3 py-1 bg-white/10 rounded-full text-xs uppercase tracking-wider text-white/60">
            Dev Notice
          </div>
          <h2 class="text-2xl md:text-3xl font-bold mb-3">Mapbox token missing</h2>
          <p class="text-white/60 leading-relaxed">
            Set <code class="bg-white/10 px-1.5 py-0.5 rounded text-sm">PUBLIC_MAPBOX_TOKEN</code> in <code class="bg-white/10 px-1.5 py-0.5 rounded text-sm">.env</code> and restart the dev server.
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="bg-[#111] py-20">
    <div class="container-custom text-center">
      <h2 class="text-white mb-4 text-2xl md:text-3xl">The phosphorus is already in the ground.<br/>The question is who unlocks it.</h2>
      <p class="text-white/50 mb-8 max-w-xl mx-auto">
        HeartsBio's enzyme technology aims to improve phosphorus-use efficiency — with the potential to reduce waste, improve input efficiency, and support environmental goals.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/products" class="btn btn-primary">
          Explore Our Products
        </a>
        <a href="/#contact" class="btn border-2 border-white/20 text-white hover:bg-white/10 transition-all">
          Get in Touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
