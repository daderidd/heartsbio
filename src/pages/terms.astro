---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service - HeartsBio" description="Terms of Service for HeartsBio website">
  <div class="min-h-screen bg-cream dark:bg-[#1a1a1a] py-20">
    <div class="container-custom max-w-4xl">
      <div class="bg-white dark:bg-[#111] rounded-3xl p-8 md:p-12 shadow-sm">
        <!-- Header -->
        <div class="mb-8">
          <div class="inline-block mb-4 px-4 py-2 bg-dark-green/10 dark:bg-white/10 rounded-full">
            <span class="text-dark-green dark:text-cream font-semibold text-sm tracking-wide">LEGAL</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-display font-bold text-black dark:text-white mb-4">
            Terms of Service
          </h1>
          <p class="text-lg text-black/70 dark:text-white/60">
            Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        </div>

        <!-- Content -->
        <div class="prose prose-lg max-w-none">
          <h2 class="text-2xl font-display font-bold text-black dark:text-white mb-4">Website Use</h2>
          <p class="text-black/70 dark:text-white/60 mb-6">
            This website is provided for informational purposes about HeartsBio's biotechnology research and development services. By using this website, you agree to:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-black/70 dark:text-white/60 mb-8">
            <li>Use the website in compliance with applicable laws and regulations</li>
            <li>Not use the website for any unlawful or prohibited purposes</li>
            <li>Respect intellectual property rights of HeartsBio</li>
            <li>Not attempt to gain unauthorized access to any part of the website</li>
          </ul>

          <h2 class="text-2xl font-display font-bold text-black dark:text-white mb-4">Intellectual Property</h2>
          <p class="text-black/70 dark:text-white/60 mb-8">
            All content on this website, including text, graphics, logos, and images, is the property of HeartsBio and is protected by Dutch and international copyright laws.
          </p>

          <h2 class="text-2xl font-display font-bold text-black dark:text-white mb-4">Limitation of Liability</h2>
          <p class="text-black/70 dark:text-white/60 mb-8">
            While we strive to ensure the information on this website is accurate and up-to-date, HeartsBio makes no representations or warranties of any kind regarding the website or its content.
          </p>

          <h2 class="text-2xl font-display font-bold text-black dark:text-white mb-4">Governing Law</h2>
          <p class="text-black/70 dark:text-white/60 mb-8">
            These terms and your use of this website are governed by the laws of the Netherlands.
          </p>

          <h2 class="text-2xl font-display font-bold text-black dark:text-white mb-4">Contact Us</h2>
          <p class="text-black/70 dark:text-white/60 mb-4">
            If you have any questions about these terms, please contact us:
          </p>
          <div class="bg-cream rounded-xl p-6">
            <p class="text-black/70 dark:text-white/60 mb-2">
              <strong>Email:</strong> <a href="mailto:info@heartsbio.nl" class="text-dark-green dark:text-cream hover:underline">info@heartsbio.nl</a>
            </p>
            <p class="text-black/70 dark:text-white/60">
              <strong>Location:</strong> The Netherlands
            </p>
          </div>
        </div>

        <!-- Back Link -->
        <div class="mt-12 pt-8 border-t border-black/10">
          <a href="/" class="inline-flex items-center gap-2 text-dark-green hover:text-green transition-colors font-semibold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Back to Home
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
