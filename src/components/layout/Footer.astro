---
const currentYear = new Date().getFullYear();

const footerLinks = {
  company: [
    { label: 'Our Team', href: '/#team' },
    { label: 'Technology', href: '/#solution' },
    { label: 'Products', href: '/#portfolio' },
    { label: 'Contact', href: '/#contact' },
  ],
  // resources: [
  //   { label: 'Case Studies', href: '/portfolio#case-studies' },
  //   { label: 'Research', href: '/portfolio#research' },
  //   { label: 'News', href: '/news' },
  // ],
  legal: [
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
  ],
};

const socialLinks = [
  // Add social media links as needed
  // { label: 'LinkedIn', href: '#', icon: 'linkedin' },
  // { label: 'Twitter', href: '#', icon: 'twitter' },
];
---

<footer class="bg-gradient-to-b from-dark-green to-black text-white">
  <!-- Main Footer Content -->
  <div class="container-custom py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 group" aria-label="HeartsBio home">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center p-1.5">
            <svg viewBox="130 700 240 250" class="w-full h-full" fill="#1d261d" aria-hidden="true"><path d="m 244.70109,791.79085 c -3.11096,-12.20025 -8.29236,-22.8637 -16.95615,-31.63647 -10.42939,-10.56049 -21.48985,-10.25842 -31.3594,0.94897 -11.96327,13.58496 -12.83885,29.16474 -7.3131,45.44617 4.82431,14.21472 13.96373,26.02936 22.55536,38.11481 8.96344,12.60852 17.79295,25.3139 26.52458,38.08392 1.76603,2.58289 2.75708,5.68396 4.23835,8.47565 2.65359,5.0011 7.09829,5.42456 10.08447,0.77362 15.55649,-24.22864 28.40491,-49.76227 35.39276,-77.83368 2.80576,-11.27118 4.6673,-22.789 2.93249,-34.61707 -3.11621,-21.24682 -14.0126,-33.36749 -34.97436,-38.46179 -1.94705,-0.4732 -3.71222,-1.69488 -5.56183,-2.56897 1.22894,-1.85974 2.0585,-4.27929 3.75223,-5.48761 10.33969,-7.37643 21.12652,-14.23211 33.7662,-16.71606 16.56867,-3.25614 31.00321,2.74341 43.63544,12.80139 18.84045,15.00116 24.27856,36.16254 23.93185,58.88123 -0.3703,24.26751 -10.23794,44.98352 -27.87063,61.5595 -27.78116,26.11634 -55.94653,51.82404 -83.95993,77.69318 -0.21826,0.2016 -0.58457,0.24286 -1.09592,0.44269 -21.1822,-26.47461 -49.53931,-45.1181 -74.65335,-67.35895 -16.6199,-14.7185 -29.49341,-31.80737 -34.76196,-53.59302 -6.91417,-28.59008 -1.86028,-54.62536 19.02615,-76.36139 8.78998,-9.14749 19.954,-14.1315 32.62865,-14.0541 9.05351,0.0553 18.43548,0.52099 27.07017,2.94415 14.97196,4.20151 23.95273,15.50333 29.63941,29.61185 5.27838,13.09558 6.16171,26.84253 6.11828,40.71783 -0.005,1.7182 -0.79498,3.43384 -1.43087,5.99536 -0.61457,-1.65716 -0.94217,-2.54059 -1.35889,-3.80121 z"/></svg>
          </div>
          <span class="font-display font-bold text-2xl text-white group-hover:text-cream transition-colors">
            HeartsBio
          </span>
        </a>
        <p class="text-sm text-white/70 mb-4">
          Advancing biotechnology through innovative research and development.
        </p>
        <div class="flex gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class="text-white/70 hover:text-white transition-colors"
              aria-label={link.label}
            >
              <!-- Social icons would go here -->
            </a>
          ))}
        </div>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/70 hover:text-white transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Contact</h3>
        <ul class="space-y-2 text-sm text-white/70">
          <li>
            <a href="mailto:info@heartsbio.nl" class="hover:text-white transition-colors" aria-label="Email info@heartsbio.nl">
              info@heartsbio.nl
            </a>
          </li>
          <li class="pt-2">
            The Netherlands
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container-custom py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-white/50">
          © {currentYear} HeartsBio. All rights reserved.
        </p>
        <div class="flex gap-6">
          {footerLinks.legal.map((link) => (
            <a
              href={link.href}
              class="text-sm text-white/50 hover:text-white transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
