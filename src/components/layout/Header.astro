---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Technology', href: '/#technology' },
  { label: 'Products', href: '/products' },
  { label: 'About', href: '/#about' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-4 left-0 right-0 z-50 px-4">
  <nav class="max-w-7xl mx-auto bg-white/95 backdrop-blur-sm shadow-lg rounded-2xl px-6 py-4 border border-black/5" aria-label="Main navigation">
    <div class="flex items-center justify-between">
      <!-- Logo/Brand -->
      <a href="/" class="flex items-center gap-2 group" aria-label="HeartsBio home">
        <div class="w-10 h-10 bg-dark-green rounded-lg flex items-center justify-center p-1.5">
          <svg viewBox="130 700 240 250" class="w-full h-full" fill="white" aria-hidden="true"><path d="m 244.70109,791.79085 c -3.11096,-12.20025 -8.29236,-22.8637 -16.95615,-31.63647 -10.42939,-10.56049 -21.48985,-10.25842 -31.3594,0.94897 -11.96327,13.58496 -12.83885,29.16474 -7.3131,45.44617 4.82431,14.21472 13.96373,26.02936 22.55536,38.11481 8.96344,12.60852 17.79295,25.3139 26.52458,38.08392 1.76603,2.58289 2.75708,5.68396 4.23835,8.47565 2.65359,5.0011 7.09829,5.42456 10.08447,0.77362 15.55649,-24.22864 28.40491,-49.76227 35.39276,-77.83368 2.80576,-11.27118 4.6673,-22.789 2.93249,-34.61707 -3.11621,-21.24682 -14.0126,-33.36749 -34.97436,-38.46179 -1.94705,-0.4732 -3.71222,-1.69488 -5.56183,-2.56897 1.22894,-1.85974 2.0585,-4.27929 3.75223,-5.48761 10.33969,-7.37643 21.12652,-14.23211 33.7662,-16.71606 16.56867,-3.25614 31.00321,2.74341 43.63544,12.80139 18.84045,15.00116 24.27856,36.16254 23.93185,58.88123 -0.3703,24.26751 -10.23794,44.98352 -27.87063,61.5595 -27.78116,26.11634 -55.94653,51.82404 -83.95993,77.69318 -0.21826,0.2016 -0.58457,0.24286 -1.09592,0.44269 -21.1822,-26.47461 -49.53931,-45.1181 -74.65335,-67.35895 -16.6199,-14.7185 -29.49341,-31.80737 -34.76196,-53.59302 -6.91417,-28.59008 -1.86028,-54.62536 19.02615,-76.36139 8.78998,-9.14749 19.954,-14.1315 32.62865,-14.0541 9.05351,0.0553 18.43548,0.52099 27.07017,2.94415 14.97196,4.20151 23.95273,15.50333 29.63941,29.61185 5.27838,13.09558 6.16171,26.84253 6.11828,40.71783 -0.005,1.7182 -0.79498,3.43384 -1.43087,5.99536 -0.61457,-1.65716 -0.94217,-2.54059 -1.35889,-3.80121 z"/></svg>
        </div>
        <span class="font-display font-bold text-2xl text-black group-hover:text-green transition-colors">
          HeartsBio
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'font-medium transition-colors',
              currentPath === item.href
                ? 'text-dark-green'
                : 'text-black/70 hover:text-dark-green'
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- CTA Button (Desktop) -->
      <div class="hidden md:block">
        <a href="#contact" class="btn btn-primary" aria-label="Contact us">
          Get in Touch
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 text-black/70 hover:text-dark-green transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-gray-200 pt-4" role="menu">
      <div class="flex flex-col gap-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'font-medium transition-colors py-2',
              currentPath === item.href
                ? 'text-dark-green'
                : 'text-black/70 hover:text-dark-green'
            ]}
          >
            {item.label}
          </a>
        ))}
        <a href="#contact" class="btn btn-primary mt-2">
          Get in Touch
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    const isExpanded = mobileMenu?.classList.toggle('hidden');
    menuButton.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
  });

  // Smooth scrolling for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (href && href !== '#') {
        e.preventDefault();
        const targetId = href.substring(1);
        const targetElement = document.getElementById(targetId);

        if (targetElement) {
          targetElement.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
          // Close mobile menu after clicking
          mobileMenu?.classList.add('hidden');
        }
      }
    });
  });
</script>
