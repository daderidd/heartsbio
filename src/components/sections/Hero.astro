---
// Hero Section - Modern, clean hero with background image
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden -mt-24 pt-24">
  <!-- Background Video with Overlay -->
  <div class="absolute inset-0 top-0 z-0">
    <video
      autoplay
      loop
      muted
      playsinline
      preload="auto"
      poster="/videos/hero-poster.jpg"
      class="w-full h-full object-cover"
    >
      <source src="/videos/hero-field.mp4" type="video/mp4" />
      Your browser does not support the video tag.
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-dark-green/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container-custom text-center text-white py-20 mt-16">
    <div class="max-w-4xl mx-auto">
      <!-- Main Headline with Rotating Text -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold mb-12 leading-tight hero-fade hero-fade-1">
        Unlocking the Phosphorus<br />
        <span id="rotating-word" class="inline-block transition-all duration-500 ease-in-out">Already</span> in Your Soil
      </h1>

      <!-- Subheadline -->
      <div class="mb-16 max-w-3xl mx-auto hero-fade hero-fade-2">
        <p class="text-xl md:text-2xl text-white/90 leading-relaxed">
          <span class="font-bold">Enzyme technology that turns locked soil nutrients into crop performance.</span>
          <br />
          Backed by decades of R&D. Proven in the field. Ready to scale.
        </p>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center hero-fade hero-fade-3">
        <a href="#problem" class="btn text-lg px-10 py-4 bg-white text-dark-green hover:bg-cream hover:shadow-xl hover:-translate-y-1 transition-all shadow-lg animate-pulse-glow" aria-label="Learn about the opportunity">
          See the Opportunity
        </a>
        <a href="#solution" class="btn text-lg px-10 py-4 border-2 border-white text-white hover:bg-white hover:text-dark-green hover:shadow-xl hover:-translate-y-1 transition-all" aria-label="Learn about our solution">
          Our Solution
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 animate-bounce">
    <a href="#technology" class="text-white/80 hover:text-white transition-colors" aria-label="Scroll to technology section">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </a>
  </div>
</section>

<style>
  /* Rotating text animation — fixed width so surrounding text doesn't shift */
  #rotating-word {
    display: inline-block;
    width: 3.8em;
    text-align: center;
  }

  .word-fade-out {
    animation: fadeOut 0.4s ease-in-out forwards;
  }

  .word-fade-in {
    animation: fadeIn 0.4s ease-in-out forwards;
  }

  @keyframes fadeOut {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Hero entrance animations */
  .hero-fade {
    opacity: 0;
    transform: translateY(30px);
    animation: heroFadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-fade-1 { animation-delay: 0.2s; }
  .hero-fade-2 { animation-delay: 0.5s; }
  .hero-fade-3 { animation-delay: 0.8s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect user's motion preferences */
  @media (prefers-reduced-motion: reduce) {
    #hero video {
      display: none;
    }
    .hero-fade {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<script>
  // Rotating text functionality
  const words = ['Already', 'Locked', 'Waiting', 'Hidden'];
  let currentIndex = 0;
  const rotatingElement = document.getElementById('rotating-word');

  function rotateWord() {
    if (!rotatingElement) return;

    // Fade out
    rotatingElement.classList.add('word-fade-out');

    setTimeout(() => {
      // Change word
      currentIndex = (currentIndex + 1) % words.length;
      rotatingElement.textContent = words[currentIndex];

      // Fade in
      rotatingElement.classList.remove('word-fade-out');
      rotatingElement.classList.add('word-fade-in');

      setTimeout(() => {
        rotatingElement.classList.remove('word-fade-in');
      }, 400);
    }, 400);
  }

  // Start rotation
  setInterval(rotateWord, 3000); // Change word every 3 seconds
</script>
