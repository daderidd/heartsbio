---
// Fitazim Spotlight — Homepage flagship product section
import { Image } from 'astro:assets';
import fitazimTrial1 from '../../assets/images/products/Fitazim Trial 1.webp';
import fitazimTrial2 from '../../assets/images/products/Fitazim Trial 1-2.webp';
---

<section id="fitazim" class="section bg-cream overflow-hidden">
  <div class="container-custom">
    <!-- Header -->
    <div class="max-w-4xl mx-auto text-center mb-14 reveal">
      <div class="inline-block mb-4 px-4 py-2 bg-dark-green/8 rounded-full">
        <span class="text-dark-green font-semibold text-sm tracking-wide">FLAGSHIP PRODUCT</span>
      </div>
      <h2 class="text-black mb-4">
        Meet Fitazim
      </h2>
      <p class="text-lg text-black/50 max-w-2xl mx-auto">
        Our proprietary enzyme formulation that unlocks bound phosphorus from the soil — turning a wasted resource into plant nutrition.
      </p>
    </div>

    <!-- Content: Stats + Trial Images -->
    <div class="max-w-6xl mx-auto">
      <!-- Key results bar -->
      <div class="grid grid-cols-3 gap-4 md:gap-6 mb-12 reveal">
        <div class="text-center p-5 md:p-6 bg-white rounded-2xl shadow-sm border border-dark-green/5">
          <div class="text-3xl md:text-4xl font-display font-bold text-dark-green">+79%</div>
          <div class="text-xs md:text-sm text-black/40 mt-1 font-medium">Phosphorus recovery</div>
        </div>
        <div class="text-center p-5 md:p-6 bg-white rounded-2xl shadow-sm border border-dark-green/5">
          <div class="text-3xl md:text-4xl font-display font-bold text-dark-green">+46%</div>
          <div class="text-xs md:text-sm text-black/40 mt-1 font-medium">Crop growth</div>
        </div>
        <div class="text-center p-5 md:p-6 bg-white rounded-2xl shadow-sm border border-dark-green/5">
          <div class="text-3xl md:text-4xl font-display font-bold text-dark-green">35 days</div>
          <div class="text-xs md:text-sm text-black/40 mt-1 font-medium">Trial duration</div>
        </div>
      </div>

      <!-- Trial comparison -->
      <div class="grid md:grid-cols-2 gap-5 mb-10">
        <div class="reveal-left group relative rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden">
            <Image
              src={fitazimTrial1}
              alt="Control plants without Fitazim"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={1072}
              height={628}
              quality={90}
            />
          </div>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4">
            <span class="text-white text-sm font-semibold">Control (untreated)</span>
          </div>
        </div>
        <div class="reveal-right group relative rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden">
            <Image
              src={fitazimTrial2}
              alt="Fitazim-treated plants showing improved growth"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={1224}
              height={898}
              quality={90}
            />
          </div>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-dark-green/70 to-transparent p-4">
            <span class="text-white text-sm font-semibold">Fitazim-treated</span>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center reveal">
        <a
          href="/products#fitazim"
          class="inline-flex items-center gap-2 px-8 py-4 bg-dark-green text-white font-semibold rounded-full hover:bg-green hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 shadow-lg group"
        >
          See the Full Trial Data
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
