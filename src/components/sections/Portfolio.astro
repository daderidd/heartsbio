---
// Products Section - Showcase our biological solutions
import { Image } from 'astro:assets';
import leavesBg from '../../assets/images/products/leaves-bg.webp';
import enhancedFertilizer from '../../assets/images/R&D portfolio/enhanced-fertilizer.webp';
import climateStress from '../../assets/images/R&D portfolio/climate-stress-alleviator.webp';
import seedCoating from '../../assets/images/R&D portfolio/seed-coating.webp';

const products = [
  {
    id: 'fitazim',
    name: 'Fitazim',
    title: 'Proven Phosphorus Booster',
    category: 'Phosphate Uptake Solutions',
    description: 'Fitazim uses powerful synergistic enzyme combinations to release residual soil phosphorus reserves, especially phytate form-P.',
    image: leavesBg,
    benefits: [
      'More plant-available phosphorus through synergistic enzyme action',
      'Stronger, faster crop development and consistently higher yields',
      'Recovering residual "legacy phosphorus" from soil',
      'Less phosphorus runoff, protecting water ecosystems',
    ],
    tagline: 'Maximum phosphorus efficiency, powered by pure enzyme synergy',
  },
  {
    id: 'bio-dop',
    name: 'Bio-Dop',
    title: 'Enzymatic Fertilizer Coating',
    category: 'Phosphate Uptake Solutions',
    description: 'An upstream enzymatic solution designed to enhance the performance of phosphate-based chemical fertilizers, and many others, by improving phosphorus uptake from the production stage onward.',
    image: enhancedFertilizer,
    benefits: [
      'Upstream solution for maximizing phosphorus efficiency',
      'Easy to integrate into existing production lines',
      'High ROI across the entire value chain',
      'Reduces dependence on finite phosphorus reserves',
    ],
    tagline: 'Enhancing fertilizer performance from production to field',
  },
  {
    id: 'purisol',
    name: 'Purisol',
    title: 'Full Microbiota Transfer',
    category: 'Microbiota Transfer',
    description: '100% natural, unprocessed, plant-based prebiotic. Serves as an optimal carrier for Plant Growth-Promoting Bacteria (PGPB), enhancing microbial colonization and activity.',
    image: climateStress,
    benefits: [
      'Enhances tolerance to drought, salinity, and soil-borne diseases',
      'Promotes vigorous growth and stronger root systems',
      'Increases fruit, kernel, and calyx size and weight',
      'Provides earliness, longer picking periods, and shelf life',
    ],
    tagline: 'Ecocert-certified, natural prebiotic for sustainable farming',
    certification: 'Ecocert Certified',
  },
  {
    id: 'sg-2',
    name: 'SG-2',
    title: 'Enzymatic Seed Coating',
    category: 'Seed Coating',
    description: 'A strong crop starts with a strong seed. SG-2 delivers performance from the very beginning.',
    image: seedCoating,
    benefits: [
      'Faster, more uniform germination',
      'Early root development',
      'Enhanced nutrient absorption',
      'Improved stress tolerance',
    ],
    tagline: 'Superior seed performance for optimal crop establishment',
  },
];
---

<section id="portfolio" class="section bg-white dark:bg-[#111]">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12 reveal">
      <div class="inline-block mb-4 px-4 py-2 bg-green/10 dark:bg-white/10 rounded-full">
        <span class="text-dark-green dark:text-cream font-semibold text-sm tracking-wide">PRODUCT PORTFOLIO</span>
      </div>
      <h2 class="text-black dark:text-white mb-4">
        Four Products, One Mission
      </h2>
      <p class="text-lg text-black/50 dark:text-white/50">
        Each product targets a different stage of the agricultural cycle — from soil preparation to seed to harvest.
      </p>
    </div>

    <!-- Compact Products Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {products.map((product, index) => (
        <a
          href={`/products#${product.id}`}
          class={`group relative rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-500 hover:-translate-y-2 cursor-pointer block reveal stagger-${index + 1}`}
          aria-label={`Learn more about ${product.name}`}
        >
          <div class="aspect-[3/4] overflow-hidden">
            <Image
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
              width={500}
              height={667}
              quality={80}
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-dark-green/90 via-dark-green/30 to-transparent"></div>

          {product.certification && (
            <div class="absolute top-3 right-3">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/90 backdrop-blur-sm text-dark-green text-xs font-semibold rounded-full">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                {product.certification}
              </span>
            </div>
          )}

          <div class="absolute bottom-0 left-0 right-0 p-5">
            <div class="text-[10px] uppercase tracking-wider text-white/50 font-semibold mb-1">{product.category}</div>
            <h3 class="text-xl font-display font-bold text-white mb-1">{product.name}</h3>
            <p class="text-sm text-white/70 leading-snug mb-3">{product.title}</p>
            <div class="flex items-center gap-1.5 text-cream text-sm font-semibold group-hover:gap-2.5 transition-all">
              <span>Learn more</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- View All CTA -->
    <div class="text-center mt-12">
      <a
        href="/products"
        class="inline-flex items-center gap-2 text-dark-green dark:text-cream font-semibold hover:gap-3 transition-all group"
      >
        <span>Explore all products in detail</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
