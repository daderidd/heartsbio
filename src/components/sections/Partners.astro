---
// Partners / Affiliations — logo strip for credibility
const partners = [
  { name: 'The Fertilizer Institute', url: 'https://www.tfi.org/' },
  { name: 'EcoCert', url: 'https://www.ecocert.com/' },
  { name: 'Yes We Trust', url: 'https://www.yeswetrustlabel.com/' },
  { name: 'Top Tier Impact', url: 'https://www.toptierimpact.com/' },
  { name: 'Sabancı University', url: 'https://www.sabanciuniv.edu/' },
];
---

<section class="py-12 md:py-16 bg-white dark:bg-[#111] border-y border-black/5 dark:border-white/5">
  <div class="container-custom">
    <p class="text-center text-xs uppercase tracking-wider text-black/30 dark:text-white/25 font-semibold mb-8">
      Member of &amp; affiliated with
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 md:gap-x-16">
      {partners.map((p) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-black/40 dark:text-white/30 hover:text-black/70 dark:hover:text-white/60 transition-colors text-sm md:text-base font-semibold tracking-wide whitespace-nowrap"
          title={p.name}
        >
          {p.name}
        </a>
      ))}
    </div>
  </div>
</section>
