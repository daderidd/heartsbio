---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/CookieConsent';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
}

const {
  title,
  description = "HeartsBio is a Dutch biotech R&D company developing enzyme-based solutions for sustainable agriculture — phosphate bioavailability, biopesticides, microbial soil health, and advanced seed coatings. Products by Supersol in Turkey.",
  image = "/videos/hero-poster.jpg",
  keywords = "HeartsBio, heartsbio.nl, Supersol, biotechnology, agricultural biotech, enzyme technology, phosphorus recovery, phosphate bioavailability, nutrient bioavailability, biopesticides, biocontrol, microbial solutions, seed coating, sustainable farming, soil health, Fitazim, Purisol, Bio-Dop, SG-2, Netherlands, Europe, Turkey, biotech R&D"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = "HeartsBio";

// Structured data for organization
const orgStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteName,
  "alternateName": "HeartsBio B.V.",
  "url": "https://www.heartsbio.nl",
  "logo": new URL("/favicon.svg", Astro.site),
  "description": "Dutch biotech R&D company developing enzyme-based biological solutions for sustainable agriculture.",
  "foundingDate": "2020",
  "areaServed": ["Europe", "United States", "Turkey"],
  "knowsAbout": ["Enzyme technology", "Phosphorus recovery", "Phosphate bioavailability", "Nutrient bioavailability", "Biopesticides", "Biocontrol", "Microbial soil health", "Seed coating technology", "Sustainable agriculture"],
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "NL"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "info@heartsbio.nl",
    "contactType": "customer service"
  },
  "sameAs": []
};

// WebSite structured data for sitelinks search box
const webSiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "url": "https://www.heartsbio.nl"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#1d261d" />

    <!-- Preload hero poster for fast first paint -->
    <link rel="preload" as="image" href="/videos/hero-poster.jpg" type="image/jpeg" />

    <!-- Preconnect to Google Fonts for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={siteName} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Geo targeting — EU, US, Turkey -->
    <meta name="geo.region" content="NL" />
    <meta name="geo.placename" content="Netherlands" />
    <meta name="DC.coverage" content="Europe, United States, Turkey" />

    <!-- Language -->
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgStructuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteStructuredData)} />

    <!-- Google Analytics (respects cookie consent) -->
    <GoogleAnalytics />
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <CookieConsent client:only="react" />
  </body>
</html>
